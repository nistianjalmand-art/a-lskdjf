# ── MT5 Zugangsdaten (optional) ──────────────────────────────────────────────
# Nur ausfüllen, wenn das MT5-Terminal beim Backend-Start noch nicht eingeloggt ist.
# Wenn MT5 bereits geöffnet und verbunden ist, können diese leer bleiben.
MT5_LOGIN=12345678
MT5_PASSWORD=dein_passwort
MT5_SERVER=BrokerName-Demo

# ── Telegram Alerts ───────────────────────────────────────────────────────────
# Bot-Token von @BotFather, Chat-ID von @userinfobot
TELEGRAM_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=987654321
TELEGRAM_ENABLED=true

# ── Struktur-Analyse ──────────────────────────────────────────────────────────
PIVOT_LENGTH=1                # Pivot Left/Right Länge (1 = Standard wie TV-Skript)
MONITOR_INTERVAL=10           # Sekunden zwischen Background-Monitor-Durchläufen

# Umbenennen zu .env und Werte eintragen:
# cp .env.example .env
